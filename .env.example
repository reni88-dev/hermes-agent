# =============================================================================
# Hermes Agent — Environment Variables (Referensi)
# =============================================================================
# File ini hanya sebagai referensi. Di Easypanel, environment variables
# dikonfigurasi via UI Easypanel atau via 'hermes setup' di terminal container.
#
# Hermes menyimpan konfigurasinya di /opt/data/.env dan /opt/data/config.yaml
# setelah menjalankan 'hermes setup'.
# =============================================================================

# Timezone (sudah di-set di Dockerfile)
# TZ=Asia/Jakarta

# UID/GID container (opsional)
# HERMES_UID=1000
# HERMES_GID=1000
