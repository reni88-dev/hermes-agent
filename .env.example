# ============================================================================
# Hermes Agent v0.15.2 — Environment Variables
# ============================================================================
# File ini OPSIONAL. Anda bisa mengkonfigurasi semuanya via "hermes setup".
# Salin file ini ke .env dan isi sesuai kebutuhan.
# ============================================================================

# ─── Timezone ───
TZ=Asia/Jakarta

# ─── s6-overlay UID/GID remapping (opsional) ───
# Sesuaikan dengan UID/GID host user pemilik data volume
# agar file yang dibuat container tetap readable/writable di host.
# HERMES_UID=1000
# HERMES_GID=1000

# ─── LLM Provider (pilih salah satu) ───
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Nous Portal (provider native Nous Research) ───
# NOUS_API_KEY=...

# ─── Model (opsional, bisa diset via hermes model) ───
# HERMES_MODEL=openrouter/nous-hermes

# ─── Telegram ───
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_ALLOWED_USERS=username1,username2

# ─── Discord ───
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=userid1,userid2

# ─── Slack ───
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USERS=

# ─── WhatsApp ───
# WHATSAPP_ENABLED=true
# WHATSAPP_MODE=bot

# ─── Signal ───
# SIGNAL_HTTP_URL=http://127.0.0.1:8080
# SIGNAL_ACCOUNT=+1234567890
# SIGNAL_ALLOWED_USERS=

# ─── Email ───
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=
# EMAIL_IMAP_HOST=
# EMAIL_SMTP_HOST=

# ─── Matrix (Baru!) ───
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_USER_ID=@hermes:matrix.org
# MATRIX_ACCESS_TOKEN=

# ─── API Server (untuk integrasi external) ───
# API_SERVER_ENABLED=true
# API_SERVER_KEY=your-secret-key
# API_SERVER_HOST=0.0.0.0
# API_SERVER_PORT=8642

# ─── Webhook ───
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=8642
# WEBHOOK_SECRET=your-webhook-secret

# ─── Agent Behavior ───
# HERMES_MAX_ITERATIONS=50
# HERMES_API_TIMEOUT=900
# HERMES_QUIET=false

# ==============================================================================
# ADVANCED / EXPERIMENTAL SETTINGS (v0.15.2)
# ==============================================================================

# -- Browser Automation --
# Secara default, Hermes menggunakan Playwright Chromium (lokal di dalam container).
# Jika Anda ingin menghemat resource RAM container dengan memindahkan proses web-scraping
# ke cloud (serverless), Anda bisa menggunakan layanan Browserbase.
# BROWSERBASE_API_KEY="your-browserbase-api-key"
# BROWSERBASE_PROJECT_ID="your-project-id"

# -- Keamanan Eksekusi Terminal (DIND) --
# Default terminal tool berjalan 'local' di dalam container Hermes.
# Jika Anda mengaktifkan mount /var/run/docker.sock di konfigurasi volume EasyPanel,
# Anda bisa menge-set TERMINAL_ENV=docker untuk menginstruksikan Hermes agar mengisolasi
# shell prosesnya ke sub-container sementara yang aman.
# TERMINAL_ENV="local" # Ubah ke "docker" jika docker socket mount diaktifkan
# TERMINAL_DOCKER_IMAGE="nikolaik/python-nodejs:python3.13-nodejs22"
# TERMINAL_TIMEOUT=60

# -- Bitwarden Secrets Manager (Baru di v0.15.x!) --
# Ganti semua API key terpisah dengan satu bootstrap token.
# Hermes akan otomatis resolve semua secrets dari Bitwarden vault.
# BWS_ACCESS_TOKEN="your-bitwarden-access-token"

# -- xAI Integration (Baru!) --
# GROK_API_KEY="your-grok-api-key"

# -- Image Generation (Baru: Krea 2 support!) --
# FAL_KEY="your-fal-api-key"
