# ============================================================================
# Hermes Agent — Environment Variables
# ============================================================================
# File ini OPSIONAL. Anda bisa mengkonfigurasi semuanya via "hermes setup".
# Salin file ini ke .env dan isi sesuai kebutuhan.
# ============================================================================

# ─── Timezone ───
TZ=Asia/Jakarta

# ─── LLM Provider (pilih salah satu) ───
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Model (opsional, bisa diset via hermes model) ───
# HERMES_MODEL=openrouter/nous-hermes

# ─── Telegram ───
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_ALLOWED_USERS=username1,username2

# ─── Discord ───
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=userid1,userid2

# ─── Slack ───
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USERS=

# ─── WhatsApp ───
# WHATSAPP_ENABLED=true
# WHATSAPP_MODE=bot

# ─── Signal ───
# SIGNAL_HTTP_URL=http://127.0.0.1:8080
# SIGNAL_ACCOUNT=+1234567890
# SIGNAL_ALLOWED_USERS=

# ─── Email ───
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=
# EMAIL_IMAP_HOST=
# EMAIL_SMTP_HOST=

# ─── API Server (untuk integrasi external) ───
# API_SERVER_ENABLED=true
# API_SERVER_KEY=your-secret-key
# API_SERVER_HOST=0.0.0.0
# API_SERVER_PORT=8642

# ─── Webhook ───
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=8644
# WEBHOOK_SECRET=your-webhook-secret

# ─── Agent Behavior ───
# HERMES_MAX_ITERATIONS=50
# HERMES_API_TIMEOUT=900
# HERMES_QUIET=false
