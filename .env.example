# =============================================================================
# Hermes Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values you need.
#
# Most configuration (LLM provider, model, messaging channels) is handled
# interactively via:
#   docker compose run --rm hermes setup
#
# This file provides runtime settings for the Docker container itself.
# =============================================================================

# =============================================================================
# CONTAINER SETTINGS
# =============================================================================

# UID/GID for the hermes user inside the container.
# Set these to match the host user that owns the data volume.
# On Linux: HERMES_UID=$(id -u) HERMES_GID=$(id -g)
# HERMES_UID=1000
# HERMES_GID=1000

# Alternative names (LinuxServer.io / NAS convention)
# PUID=1000
# PGID=1000

# =============================================================================
# API SERVER
# =============================================================================

# Gateway API server key (minimum 8 characters).
# Generate with: openssl rand -hex 32
# Required when API_SERVER_ENABLED=true
API_SERVER_KEY=change-me-to-a-strong-random-key

# =============================================================================
# LLM PROVIDER KEYS (configured via 'hermes setup')
# =============================================================================
# Uncomment and fill in the provider you want to use, OR configure
# interactively with 'hermes setup' / 'hermes model' inside the container.

# --- OpenRouter (recommended — one key for many models) ---
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# --- Anthropic (Claude) ---
# ANTHROPIC_API_KEY=

# --- Google AI Studio / Gemini ---
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# --- OpenAI ---
# OPENAI_API_KEY=

# --- Ollama Cloud ---
# OLLAMA_API_KEY=

# --- NovitaAI ---
# NOVITA_API_KEY=

# --- Kimi / Moonshot ---
# KIMI_API_KEY=

# --- Hugging Face ---
# HF_TOKEN=

# =============================================================================
# TOOL API KEYS (optional)
# =============================================================================

# Exa — AI-native web search
# EXA_API_KEY=

# Firecrawl — web search, extract, crawl
# FIRECRAWL_API_KEY=

# Parallel — AI-native web search and extract
# PARALLEL_API_KEY=

# FAL.ai — image generation
# FAL_KEY=

# =============================================================================
# MESSAGING PLATFORMS (configured via 'hermes setup')
# =============================================================================
# Uncomment the platform(s) you want to use as messaging channels.

# --- Telegram ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Discord ---
# DISCORD_BOT_TOKEN=

# --- Slack ---
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# --- WhatsApp ---
# (configured via 'hermes setup' — uses QR code pairing)
