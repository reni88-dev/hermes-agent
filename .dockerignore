# =============================================================================
# Hermes Agent — .dockerignore
# =============================================================================
# Keep the build context small. The Dockerfile extends the official image
# so almost nothing from this repo needs to be sent to the daemon.

# --- Git ---
.git
.gitignore

# --- Persistent data (never send to build) ---
hermes-data/
data/

# --- Secrets ---
.env
.env.local
.env.*.local

# --- Dependencies ---
node_modules/
**/node_modules
.venv/
**/.venv
.pip-cache/
.uv-cache/

# --- Python cache ---
__pycache__/
**/__pycache__
*.py[cod]

# --- IDE ---
.vscode/
.idea/

# --- OS ---
.DS_Store
Thumbs.db

# --- Logs & temp ---
logs/
tmp/
temp/

# --- Documentation (not needed in image) ---
README.md
LICENSE
*.md
